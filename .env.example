GITHUB_PERSONAL_ACCESS_TOKEN=your_github_token_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemini-2.5-flash

# Repo from which mmc-mcp pulls skills/models on startup (interpolated into config.json mmcGithubServer)
MMC_GITHUB_OWNER=your-github-org
MMC_GITHUB_REPO=your-skills-repo
MMC_GITHUB_PATH=models
MMC_GITHUB_BRANCH=main

# RFC-3161 Time-Stamping Authority URL for sign-enrolment's trusted timestamp.
# Unset ⇒ sign-enrolment returns rfc3161Token=null, rfc3161Status="not-configured"
# (the signed PDF + sha256 evidence-hash are still produced). When set, it POSTs
# an RFC-3161 TimeStampReq over the PDF's sha256 imprint and stores the returned
# token. Dev/test: https://freetsa.org/tsr — pick a production TSA for prod.
# MMC_RFC3161_TSA_URL=https://freetsa.org/tsr
