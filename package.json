{
  "name": "mmc-mcp",
  "version": "1.5.4",
  "packageManager": "pnpm@10.28.1",
  "description": "Model Context Protocol (MCP) server for executing business skills and proxying external MCPs",
  "main": "dist/server/index.js",
  "scripts": {
    "build": "vite build",
    "build:mcpb": "node scripts/build-mcpb.js",
    "pack:mcpb": "npx @anthropic-ai/mcpb pack dist-mcpb dist-mcpb/mmc-mcp.mcpb",
    "publish:public": "node scripts/publish-public.js",
    "start": "tsx src/server/index.ts",
    "start:force-sync": "tsx src/server/index.ts --force-sync",
    "debug": "node --inspect --import tsx src/server/index.ts",
    "debug:brk": "node --inspect-brk --import tsx src/server/index.ts",
    "dev": "tsx watch src/server/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "test:discount": "node tests/test-discount.js",
    "generate-key": "tsx scripts/generate-key.ts"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "hono",
    "llm",
    "ai",
    "business-skills"
  ],
  "author": "Arjan Noordhoek",
  "license": "(GPL-3.0-or-later AND Apache-2.0)",
  "type": "module",
  "dependencies": {
    "@azure/storage-blob": "^12.31.0",
    "@dsnp/parquetjs": "^1.8.7",
    "@hono/mcp": "^0.2.4",
    "@hono/node-server": "^2.0.4",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "dotenv": "^17.3.1",
    "hono": "^4.12.4",
    "mcp-server-sqlite": "^0.0.2",
    "pdf-lib": "^1.17.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "resend": "^6.12.4",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "devDependencies": {
    "@hono/vite-dev-server": "^0.25.0",
    "bun-types": "latest",
    "esbuild": "^0.28.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
