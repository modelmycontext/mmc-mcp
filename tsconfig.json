{
  "compilerOptions": {
    "target": "es2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": ".",
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["bun-types"],
    "paths": {
      "@connectors/*": ["./connectors/*"],
      "@sdk/*": ["./sdk/*"],
      "@src/*": ["./src/*"]
    }
  },
  "include": ["src/**/*", "connectors/**/*", "sdk/**/*"]
}
